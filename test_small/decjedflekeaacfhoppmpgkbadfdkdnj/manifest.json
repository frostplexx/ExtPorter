{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "description": "金卡登录认证",
  "manifest_version": 3,
  "name": "金卡登录认证",
  "version": "1.1",
  "icons": {
    "48": "icons/Icon.ico"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.jinka.cn/*"
      ],
      "js": [
        "ext_bridge.js",
        "src/content.js"
      ]
    },
    {
      "matches": [
        "http://*.gciot.com/*"
      ],
      "js": [
        "ext_bridge.js",
        "src/content.js"
      ]
    },
    {
      "matches": [
        "http://localhost/*"
      ],
      "js": [
        "ext_bridge.js",
        "src/content.js"
      ]
    }
  ],
  "permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [],
  "action": {
    "default_icon": "icons/Icon.ico"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ext_bridge.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}