{
  "name": "migrator",
  "version": "1.0.0",
  "description": "Migrate Extensions from Manifest v2 to v3",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "NODE_OPTIONS=\"$NODE_OPTIONS\" node dist/index.js",
    "dev": "yarn run clean; NODE_OPTIONS=\"$NODE_OPTIONS\" ts-node migrator/index.ts",
    "clean": "rm -rf tmp/output/* 2>/dev/null || true; docker exec migrator-mongodb mongosh -u admin -p password --authenticationDatabase admin migrator --eval 'db.dropDatabase()' 2>/dev/null || true",
    "debug": "yarn run build; node --inspect-brk dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:puppeteer": "jest --testPathPatterns=puppeteer",
    "db:up": "orb; docker-compose up -d mongodb",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f mongodb",
    "db:shell": "docker-compose exec mongodb mongosh migrator -u admin -p password",
    "db:admin": "open http://localhost:8081",
    "db:setup": "docker-compose up -d",
    "scripts:compare": "ts-node scripts/compare.ts",
    "scripts:search": "ts-node scripts/search-extensions.ts",
    "scripts:inspect": "ts-node scripts/inspect.ts",
    "scripts:run_ext": "scripts/chrome-temp-extension.bash",
    "lint": "eslint migrator --ext .ts",
    "lint:fix": "eslint migrator --ext .ts --fix"
  },
  "dependencies": {
    "@types/escodegen": "^0.0.10",
    "@types/espree": "^10.1.0",
    "@types/estree": "^1.0.8",
    "@types/mongodb": "^4.0.7",
    "dotenv": "^17.2.2",
    "escodegen": "^2.1.0",
    "espree": "^10.4.0",
    "file-type": "^21.0.0",
    "fs-extra": "^11.3.1",
    "jiti": "^2.6.0",
    "json5": "^2.2.3",
    "mongodb": "^6.19.0",
    "puppeteer": "^24.19.0",
    "ts-node-dev": "^2.0.0",
    "types": "^0.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@jest/globals": "^30.1.2",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.44.1",
    "winston-logs-display": "^1.0.0"
  }
}
