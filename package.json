{
    "name": "migrator",
    "version": "1.0.0",
    "description": "Migrate Extensions from Manifest v2 to v3",
    "license": "ISC",
    "author": "",
    "type": "commonjs",
    "main": "dist/index.js",
    "scripts": {
        "_build": "tsc",
        "server": "NODE_OPTIONS=\"$NODE_OPTIONS\" tsx migrator/index.ts",
        "server:watch": "NODE_OPTIONS=\"$NODE_OPTIONS\" tsx watch migrator/index.ts",
        "client": "cargo run --manifest-path ext_analyzer/Cargo.toml",
        "client:watch": "cargo watch -x 'run --manifest-path ext_analyzer/Cargo.toml'",
        "dev": "./scripts/dev.sh",
        "clean": "rm -rf logs/* || true; rm -rf tmp/output/* 2>/dev/null || true; docker exec migrator-mongodb mongosh -u admin -p password --authenticationDatabase admin migrator --eval 'db.dropDatabase()' 2>/dev/null || true",
        "debug": "yarn run _build; node --inspect-brk dist/index.js",
        "test": "jest",
        "env:init": "./scripts/init_env.sh",
        "test:full": "set -e -o pipefail; yarn _build; yarn lint; yarn test",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:unit": "jest --testPathPatterns=unit",
        "test:integration": "jest --testPathPatterns=integration",
        "test:puppeteer": "jest --testPathPatterns=puppeteer",
        "test:fakeium": "ts-node migrator/features/fakeium/demo.ts",
        "test:fakeium:unit": "jest --testPathPatterns=fakeium",
        "test:fakeium:extension": "ts-node migrator/features/fakeium/test-single-extension.ts",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down",
        "docker:logs": "docker-compose logs -f migrator-server",
        "docker:logs:all": "docker-compose logs -f",
        "docker:rebuild": "docker-compose up -d --build",
        "db:up": "docker-compose up -d mongodb",
        "db:down": "docker-compose down",
        "db:logs": "docker-compose logs -f mongodb",
        "db:shell": "docker-compose exec mongodb mongosh migrator -u admin -p password",
        "db:admin": "open http://localhost:8081",
        "db:setup": "docker-compose up -d",
        "ext": "ts-node ext_analyzer/ext.ts",
        "lint": "eslint migrator --ext .ts",
        "lint:fix": "eslint migrator --ext .ts --fix",
        "format": "nix run nixpkgs#prettier -- --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
    },
    "dependencies": {
        "@opencode-ai/sdk": "^1.0.129",
        "@types/escodegen": "^0.0.10",
        "@types/espree": "^10.1.0",
        "@types/estree": "^1.0.8",
        "@types/inquirer": "^9.0.9",
        "@types/mongodb": "^4.0.7",
        "@types/react": "^19.2.5",
        "boxen": "8.0.1",
        "chalk": "^5.6.2",
        "cheerio": "^1.1.2",
        "dotenv": "^17.2.2",
        "escodegen": "^2.1.0",
        "espree": "^11.0.0",
        "fakeium": "^0.0.8",
        "file-type": "^21.0.0",
        "fs-extra": "^11.3.1",
        "ink": "^6.5.0",
        "inquirer": "^13.0.0",
        "jiti": "^2.6.0",
        "json5": "^2.2.3",
        "mongodb": "^7.0.0",
        "puppeteer": "^24.19.0",
        "react": "^19.2.0",
        "string-width": "^8.1.0",
        "terminal-kit": "^3.1.2",
        "ts-node-dev": "^2.0.0",
        "types": "^0.1.1",
        "ws": "^8.18.3"
    },
    "devDependencies": {
        "mongodb-memory-server": "^11.0.0",
        "tar-stream": "^3.1.7",
        "@eslint/js": "^9.36.0",
        "@jest/globals": "^30.1.2",
        "@types/cheerio": "^1.0.0",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.0",
        "@types/terminal-kit": "^2.5.7",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.44.1",
        "@typescript-eslint/parser": "^8.44.1",
        "concurrently": "^9.2.1",
        "eslint": "^9.36.0",
        "globals": "^16.4.0",
        "jest": "^30.1.3",
        "ts-jest": "^29.4.1",
        "ts-node": "^10.9.2",
        "tsx": "^4.20.6",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.44.1"
    }
}
