{
  "manifest_version": 2,
  "name": "Message Passing Test Extension",
  "version": "1.0.0",
  "description": "Test extension for Chrome message passing APIs (sendMessage, connect, ports)",

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Message Passing Test"
  },

  "permissions": [
    "activeTab",
    "tabs"
  ]
}
