{
  "manifest_version": 2,
  "name": "Callback Test Extension",
  "version": "1.0.0",
  "description": "Extension that uses callback-based Chrome APIs",
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["storage", "tabs", "activeTab"]
}
