{
  "manifest_version": 2,
  "name": "New Tab Test Extension",
  "version": "1.0.0",
  "description": "A test extension that replaces the new tab page for Puppeteer testing",

  "permissions": ["storage", "bookmarks", "topSites", "tabs"],

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "icons": {
    "16": "icons/icon16.jpeg",
    "48": "icons/icon48.jpeg",
    "128": "icons/icon128.jpeg"
  },

  "web_accessible_resources": ["assets/*", "widgets/*"]
}
