{
  "manifest_version": 2,
  "name": "Context Menu Test Extension",
  "version": "1.0.0",
  "description": "Test extension with context menu onclick",
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
