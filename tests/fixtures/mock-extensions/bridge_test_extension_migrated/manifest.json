{
  "manifest_version": 3,
  "name": "Bridge Test Extension",
  "version": "1.0.0",
  "description": "Extension to test bridge injection functionality",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "ext_bridge.js",
        "content.js"
      ]
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ext_bridge.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}