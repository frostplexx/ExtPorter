{
    "manifest_version": 3,
    "name": "Bridge Test Extension",
    "version": "1.0.0",
    "description": "Extension to test bridge injection functionality",
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["*://*/*"],
            "js": ["content.js"]
        }
    ],
    "permissions": ["storage", "tabs", "activeTab"],
    "host_permissions": ["*://*/*"]
}
