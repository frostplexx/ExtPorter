{
  "manifest_version": 2,
  "name": "No Callback Test Extension",
  "version": "1.0.0",
  "description": "Extension that uses non-callback Chrome APIs",
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [{
    "matches": ["*://*/*"],
    "js": ["content.js"]
  }],
  "permissions": [
    "storage",
    "tabs"
  ]
}