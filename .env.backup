# Available log levels: error, warn, info, debug
# - error: Only error messages
# - warn: Warnings and errors
# - info: Info, warnings, and errors (recommended for development)
# - debug: All messages including debug info
# LOG_LEVEL=debug
LOG_LEVEL=info
# LOG_LEVEL=error

# MongoDB Configuration
# For local development (outside Docker) - uses root admin user
MONGODB_URI=mongodb://admin:password@localhost:27017/migrator?authSource=admin
# For Docker Compose (used by docker-compose.yml) - uses root admin user
MONGODB_URI_DOCKER=mongodb://admin:password@mongodb:27017/migrator?authSource=admin
DB_NAME=migrator

# New Tab Extensions Organization
# Set to true to organize new tab extensions into a separate subfolder
NEW_TAB_SUBFOLDER=false

# New Tab Extensions Filtering
# Set to true to completely skip processing new tab extensions
FILTER_NEW_TAB_EXTENSIONS=false

ENABLE_FAKEIUM_VALIDATION=true

# Input and output directories. This will be overwritten if pass comand line arguments
INPUT_DIR=/Users/daniel/Developer/github.com/frostplexx/Bachelor_Thesis/research/dataset/extensions
# INPUT_DIR=./tmp/input
OUTPUT_DIR=./tmp/output

# Directory for crawled cws html pages
CWS_DIR=/Users/daniel/Developer/github.com/frostplexx/Bachelor_Thesis/research/dataset/cws


# Memory management settings for large extension processing
MIGRATION_CONCURRENCY=6
MEMORY_MONITORING=true        # Enable memory usage logging

# Limit when it should warn due to high memory usage in Gb
MEMORY_WARN_LIMIT=7
# Limit when it should error due to high memory usage in Gb
MEMORY_CRIT_LIMIT=7.5


# Comment preservation settings
# Set to false to disable comment preservation for faster processing (default: true)
PRESERVE_COMMENTS=true

# LLM API Endpoint
# Supports three formats:
# 1. Local: http://localhost:11434
# 2. Remote (direct): http://remote-server.com:11434
# 3. Remote (SSH tunnel): ssh://user@host:sshport/ollamaport
#    Example: ssh://user@server.example.org:12345/11434
#    This will automatically create an SSH tunnel and forward to the remote Ollama instance
# LLM_ENDPOINT=http://localhost:11434
LLM_ENDPOINT=ssh://ra24mif@aranuka.plai.ifi.lmu.de:54321/11434

# List of ollama models: https://ollama.com/search
# LLM_MODEL=codellama:70b # doesnt wnat to do it because it thinks im tryinhg to deceive users
# LLM_MODEL=codellama:latest
# LLM_MODEL=qwen3-coder:latest
LLM_MODEL=deepseek-r1:1.5b
# LLM_MODEL=phi3.5:latest

# SSH Authentication (required when using ssh:// URLs)
# Use either password or private key:
SSH_PASSWORD=4RjpjuVGL3APfjNZoahDrqozP
# SSH_PRIVATE_KEY_PATH=/path/to/private/key

# SSH Local Port (optional, default: 11434)
# The local port to forward to when using SSH tunneling
SSH_LOCAL_PORT=11434

# Docker user/group IDs (set to your user ID to avoid permission issues)
# Run `id -u` and `id -g` to get your values
UID=1000
GID=1000

