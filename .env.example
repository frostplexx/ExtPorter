# Available log levels: error, warn, info, debug
# - error: Only error messages
# - warn: Warnings and errors
# - info: Info, warnings, and errors (recommended for development)
# - debug: All messages including debug info
LOG_LEVEL=info

# MongoDB Configuration
# For local development (outside Docker) - uses root admin user
MONGODB_URI=mongodb://admin:password@localhost:27017/migrator?authSource=admin
# For Docker Compose (used by docker-compose.yml) - uses root admin user
MONGODB_URI_DOCKER=mongodb://admin:password@mongodb:27017/migrator?authSource=admin
DB_NAME=migrator

# New Tab Extensions Organization
# Set to true to organize new tab extensions into a separate subfolder
NEW_TAB_SUBFOLDER=false

# New Tab Extensions Filtering
# Set to true to completely skip processing new tab extensions
FILTER_NEW_TAB_EXTENSIONS=false

ENABLE_FAKEIUM_VALIDATION=true

# Input and output directories. This will be overwritten if pass command line arguments
INPUT_DIR=./tmp/input
OUTPUT_DIR=./tmp/output

# Directory for crawled cws html pages
CWS_DIR=./tmp/cws

# Memory management settings for large extension processing
MIGRATION_CONCURRENCY=6
MEMORY_MONITORING=true        # Enable memory usage logging

# Limit when it should warn due to high memory usage in Gb
MEMORY_WARN_LIMIT=7
# Limit when it should error due to high memory usage in Gb
MEMORY_CRIT_LIMIT=7.5

# Comment preservation settings
# Set to false to disable comment preservation for faster processing (default: true)
PRESERVE_COMMENTS=true

# ============================================================
# LLM Configuration - Choose one of the following options:
# ============================================================

# Option 1: GitHub Copilot API (Direct API calls)
# ============================================================
# Get your token from: https://github.com/settings/tokens
# Required scopes: copilot
GITHUB_TOKEN=your_github_token_here

# Alternative: Use COPILOT_API_KEY if you have a dedicated Copilot API key
# COPILOT_API_KEY=your_copilot_api_key_here

# Copilot API Endpoint (optional, defaults to GitHub Copilot API)
COPILOT_ENDPOINT=https://api.githubcopilot.com

# LLM Model Selection for Copilot
# Available models: gpt-4, gpt-4o, gpt-3.5-turbo, etc.
# See: https://docs.github.com/en/copilot/using-github-copilot/using-github-copilot-in-the-cli
# LLM_MODEL=gpt-4o

# ============================================================
# Option 2: OpenCode SDK (Recommended)
# ============================================================
# Uses OpenCode to interact with any LLM provider
# See: https://opencode.ai/docs

# LLM Model Selection for OpenCode
# Format: "provider/model" (e.g., "anthropic/claude-3-5-sonnet-20241022")
# Available providers: anthropic, openai, google, etc.
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022

# OpenCode Server Configuration
# Port for OpenCode server (default: 4096)
OPENCODE_PORT=4096
# Hostname for OpenCode server (default: 127.0.0.1)
OPENCODE_HOSTNAME=127.0.0.1

# Set to true to connect to an existing OpenCode instance instead of starting a new one
# Useful if you already have OpenCode running in your terminal
OPENCODE_USE_EXTERNAL=false

# ============================================================
# Shared LLM Generation Parameters (both Copilot and OpenCode)
# ============================================================
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4000
LLM_TOP_P=0.85

# Docker user/group IDs (set to your user ID to avoid permission issues)
# Run `id -u` and `id -g` to get your values
UID=1000
GID=1000
