{
    "compilerOptions": {
        "target": "ES2020",
        "module": "esnext",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "jsx": "react"
    },
    "include": ["migrator", "scripts", "tests", "ext_analyzer", "ext_analyzer_old/ext.ts"],
    "exclude": ["node_modules"]
}
